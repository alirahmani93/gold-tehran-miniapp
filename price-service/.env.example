# --- server ---
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# --- storage ---
SQLITE_PATH=./data/prices.db
REDIS_URL=redis://127.0.0.1:6379/0

# --- polling ---
# every 15 minutes by default; cron syntax
POLL_CRON=*/15 * * * *
# stale tick max age (seconds) — ticks older than this are excluded from canonical aggregation
MAX_TICK_AGE_SEC=1800

# --- retention ---
# raw ticks kept for N days, then deleted by nightly job
RAW_RETENTION_DAYS=31
HOURLY_RETENTION_DAYS=120
DAILY_RETENTION_DAYS=3650

# --- sources ---
BITPIN_BASE_URL=https://api.bitpin.org
BITPIN_TIMEOUT_MS=10000

# --- FX ---
# if USDT/IRT is missing in a given poll, fall back to this many seconds of last known rate
FX_FALLBACK_MAX_AGE_SEC=3600

# --- auth ---
# comma-separated initial tokens (name:token:rate_per_min). Empty in prod — use scripts/create-token.ts
BOOTSTRAP_TOKENS=
