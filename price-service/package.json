{
  "name": "price-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Price aggregation microservice (gold, coin, crypto, FX) — Bitpin first source, SQLite + Redis storage",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "poll:once": "tsx src/scripts/poll-once.ts",
    "poll:once:prod": "node dist/scripts/poll-once.js",
    "token:create": "tsx src/scripts/create-token.ts",
    "token:create:prod": "node dist/scripts/create-token.js",
    "inspect:prod": "node dist/scripts/inspect.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
